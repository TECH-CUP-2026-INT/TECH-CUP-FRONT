{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/assets/*", "/videos/*", "/*.{png,jpg,jpeg,gif,svg,ico,mp4,webp,css,js,json,xml,txt}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
