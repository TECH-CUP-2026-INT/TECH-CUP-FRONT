# TechCup Frontend Environment Variables
# Copy this to .env and fill in the values

VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_APIM_KEY=your-apim-subscription-key

# API base URL (leave empty in dev mode to use Vite proxy)
VITE_API_BASE_URL=https://techapi.azure-api.net

# Communication service (REST prefix and WebSocket URL)
VITE_COMM_BASE_URL=/communication
VITE_COMM_WS_URL=ws://localhost:5628/ws
