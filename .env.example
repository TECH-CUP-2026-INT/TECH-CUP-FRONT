# WebSocket del chat (am-comunication-service) — va directo al backend, sin pasar por el gateway
VITE_CHAT_WS_URL=ws://localhost:5628/ws

# Google OAuth (login con Google) — vacío deshabilita el botón
VITE_GOOGLE_CLIENT_ID=

# Mercado Pago (pagos) — vacío usa la public key de test por defecto
VITE_MP_PUBLIC_KEY=
